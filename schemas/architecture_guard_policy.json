{
  "dashboard_runtime_boundary": {
    "forbidden_module_tokens": [
      "@tauri-apps/",
      "tauri-pty"
    ],
    "allowed_path_prefixes": [
      "dashboard/src/lib/platform/"
    ]
  },
  "dashboard_transport_boundary": {
