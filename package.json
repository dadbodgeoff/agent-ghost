{
  "name": "ghost-platform",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "audit:openapi-parity": "python3 scripts/check_openapi_parity.py",
    "audit:openapi-parity:strict": "python3 scripts/check_openapi_parity.py --fail-on-drift",
    "audit:studio-shape-parity": "python3 scripts/check_studio_shape_parity.py",
    "audit:studio-live": "node dashboard/scripts/live_studio_audit.mjs",
    "audit:poc-live": "node dashboard/scripts/live_poc_suite.mjs",
    "audit:infra-live": "node dashboard/scripts/live_infra_audit.mjs",
    "audit:runtime-live": "node dashboard/scripts/live_runtime_audit.mjs",
    "audit:knowledge-live": "node dashboard/scripts/live_knowledge_audit.mjs",
    "audit:io-live": "node dashboard/scripts/live_io_audit.mjs",
    "audit:distributed-live": "node dashboard/scripts/live_distributed_audit.mjs",
    "audit:convergence-live": "node dashboard/scripts/live_convergence_audit.mjs",
    "audit:database-live": "node dashboard/scripts/live_database_audit.mjs",
    "audit:surface-live": "node dashboard/scripts/live_surface_audit.mjs",
    "audit:ops-live": "node dashboard/scripts/live_ops_audit.mjs",
    "audit:preflight-live": "node dashboard/scripts/live_preflight_audit.mjs",
    "audit:soak-live": "node dashboard/scripts/live_soak_audit.mjs",
    "audit:prune-live": "node dashboard/scripts/live_prune_artifacts.mjs",
    "audit:coverage-live": "node dashboard/scripts/live_coverage_manifest.mjs",
    "audit:index-live": "node dashboard/scripts/live_artifact_index.mjs",
    "audit:critical-live": "node dashboard/scripts/live_critical_suite.mjs",
    "audit:repo-live": "node dashboard/scripts/live_repo_suite.mjs",
    "audit:dashboard-architecture": "python3 scripts/check_dashboard_architecture.py",
    "audit:ws-contract-parity": "python3 scripts/check_ws_contract_parity.py",
    "audit:generated-types-freshness": "python3 scripts/check_generated_types_freshness.py",
    "audit:architecture:strict": "pnpm audit:openapi-parity:strict && pnpm audit:studio-shape-parity && pnpm audit:dashboard-architecture && pnpm audit:ws-contract-parity && pnpm audit:generated-types-freshness",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
