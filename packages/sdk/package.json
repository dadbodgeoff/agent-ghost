{
  "name": "@ghost/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the GHOST AI Agent Platform",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "generate:types": "node scripts/generate-types.mjs"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ghost-platform/ghost",
    "directory": "packages/sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ghost",
    "ai",
    "agent",
    "sdk",
    "convergence",
    "safety"
  ]
}
